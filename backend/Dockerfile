FROM python:3.12-slim

WORKDIR /workspace

# Install system dependencies including Nmap
RUN apt-get update && apt-get install -y \
    nmap \
    curl \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8000
